# RemoteRunner — environment example
# Copy to .env and fill in values if you override defaults

# Backend server port (default: 8000)
# BACKEND_PORT=8000

# Frontend dev server port (default: 3000)
# FRONTEND_PORT=3000

# SSH connection timeout in seconds (default: 10)
# SSH_CONNECT_TIMEOUT=10

# Windows Credential Manager service name (default: RemoteRunner)
# CREDENTIAL_SERVICE_NAME=RemoteRunner
